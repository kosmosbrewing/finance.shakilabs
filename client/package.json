{
  "name": "salary-calculator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "vite build && node scripts/prerender.mjs",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
